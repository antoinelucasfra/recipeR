/* ==========================================================================
   recipeR — Dark Mode Design System
   Built for Bootstrap 5 (Shiny 1.7+)
   ========================================================================== */

/* --------------------------------------------------------------------------
   CSS Custom Properties — Design Tokens
   -------------------------------------------------------------------------- */
:root {
  /* Dark palette */
  --bg:           #0f1117;
  --surface:      #1a1d27;
  --surface-2:    #22263a;
  --surface-3:    #2a2d3e;
  --border:       #2e3347;
  --border-light: #3a3f57;

  /* Accent — indigo */
  --accent:       #6366f1;
  --accent-dark:  #4f52d4;
  --accent-glow:  rgba(99, 102, 241, 0.18);
  --accent-glow2: rgba(99, 102, 241, 0.08);

  /* Semantic */
  --success:  #10b981;
  --warning:  #f59e0b;
  --danger:   #ef4444;
  --info:     #38bdf8;

  /* Text */
  --text:       #e2e8f0;
  --text-muted: #94a3b8;
  --text-dim:   #64748b;

  /* Layout */
  --sidebar-w: 220px;
  --radius:    10px;
  --radius-sm: 6px;

  /* Shadows */
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.4);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.45);
  --shadow-lg: 0 10px 30px rgba(0,0,0,0.5);
  --shadow-xl: 0 20px 40px rgba(0,0,0,0.55);
}

/* --------------------------------------------------------------------------
   Reset & Base
   -------------------------------------------------------------------------- */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
  font-size: 14px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* Override Shiny's fluidPage padding */
.container-fluid {
  padding: 0 !important;
}

/* --------------------------------------------------------------------------
   App Shell — Sidebar + Main
   -------------------------------------------------------------------------- */
#app-shell {
  display: flex;
  min-height: 100vh;
}

/* --------------------------------------------------------------------------
   Left Sidebar
   -------------------------------------------------------------------------- */
#app-sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
  transition: transform 0.25s ease;
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  padding: 1.25rem 1.2rem 1rem;
  border-bottom: 1px solid var(--border);
}

.sidebar-logo-icon {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, var(--accent), var(--accent-dark));
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 0.9rem;
  flex-shrink: 0;
  box-shadow: 0 0 12px var(--accent-glow);
}

.sidebar-logo-text {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.3px;
}

.sidebar-nav {
  flex: 1;
  padding: 0.75rem 0.6rem;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-nav-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.6rem 0.75rem;
  border-radius: var(--radius-sm);
  cursor: pointer;
  color: var(--text-muted);
  font-size: 0.875rem;
  font-weight: 500;
  border: 1px solid transparent;
  transition: all 0.15s ease;
  text-decoration: none;
  user-select: none;
  background: transparent;
  width: 100%;
  text-align: left;
}

.sidebar-nav-item i {
  width: 16px;
  text-align: center;
  font-size: 0.85rem;
  flex-shrink: 0;
  transition: color 0.15s;
}

.sidebar-nav-item:hover {
  background: var(--surface-2);
  color: var(--text);
  border-color: var(--border);
}

.sidebar-nav-item.active {
  background: var(--accent-glow);
  color: var(--accent);
  border-color: rgba(99, 102, 241, 0.25);
}

.sidebar-nav-item.active i {
  color: var(--accent);
}

.sidebar-footer {
  padding: 0.75rem 1rem;
  border-top: 1px solid var(--border);
  font-size: 0.75rem;
  color: var(--text-dim);
}

/* --------------------------------------------------------------------------
   Main Content Area
   -------------------------------------------------------------------------- */
#main-content {
  margin-left: var(--sidebar-w);
  flex: 1;
  min-height: 100vh;
  background: var(--bg);
  overflow-y: auto;
}

.content-pane {
  display: none;
  padding: 2rem 2.5rem;
  max-width: 1280px;
}

.content-pane.active {
  display: block;
}

/* --------------------------------------------------------------------------
   Page Header
   -------------------------------------------------------------------------- */
.page-header {
  margin-bottom: 2rem;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid var(--border);
}

.page-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.4px;
  margin-bottom: 0.25rem;
}

.page-subtitle {
  color: var(--text-muted);
  font-size: 0.875rem;
}

/* --------------------------------------------------------------------------
   Stats Grid
   -------------------------------------------------------------------------- */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}

.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem 1.5rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.stat-card:hover {
  border-color: var(--border-light);
  box-shadow: var(--shadow-sm);
}

.stat-card-icon {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-sm);
  background: var(--accent-glow);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  font-size: 0.9rem;
  margin-bottom: 0.85rem;
}

.stat-value {
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--text);
  line-height: 1;
  margin-bottom: 0.35rem;
}

.stat-label {
  color: var(--text-muted);
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  font-weight: 500;
}

/* --------------------------------------------------------------------------
   Feature Cards (Home tab)
   -------------------------------------------------------------------------- */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}

.feature-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
}

.feature-card:hover {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--accent-glow), var(--shadow-md);
  transform: translateY(-2px);
}

.feature-card-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-sm);
  background: var(--accent-glow);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  font-size: 1rem;
  margin-bottom: 1rem;
}

.feature-card h5 {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 0.5rem;
}

.feature-card p {
  font-size: 0.825rem;
  color: var(--text-muted);
  line-height: 1.5;
}

/* --------------------------------------------------------------------------
   Search Bar
   -------------------------------------------------------------------------- */
.search-bar-wrap {
  position: relative;
  margin-bottom: 1.5rem;
}

.search-bar-wrap .search-icon {
  position: absolute;
  left: 1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-dim);
  font-size: 0.85rem;
  pointer-events: none;
  z-index: 2;
}

.search-bar-wrap .form-control {
  padding-left: 2.5rem;
}

.search-hint {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  background: var(--surface-3);
  color: var(--text-dim);
  font-size: 0.7rem;
  padding: 2px 6px;
  border-radius: 4px;
  border: 1px solid var(--border);
  font-family: monospace;
  pointer-events: none;
}

/* --------------------------------------------------------------------------
   Filter Panel
   -------------------------------------------------------------------------- */
.filter-panel-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 1.5rem;
  overflow: hidden;
}

.filter-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.85rem 1.25rem;
  cursor: pointer;
  user-select: none;
  border-bottom: 1px solid transparent;
  transition: background 0.15s;
}

.filter-panel-header:hover {
  background: var(--surface-2);
}

.filter-panel-header.open {
  border-bottom-color: var(--border);
}

.filter-panel-header h6 {
  font-size: 0.825rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 0;
}

.filter-panel-header .chevron {
  color: var(--text-dim);
  font-size: 0.75rem;
  transition: transform 0.2s;
}

.filter-panel-header.open .chevron {
  transform: rotate(180deg);
}

#filter_panel {
  padding: 1.25rem;
}

/* --------------------------------------------------------------------------
   Recipe Cards Grid
   -------------------------------------------------------------------------- */
.recipe-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}

.recipe-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem;
  cursor: pointer;
  transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.recipe-card:hover {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--accent-glow), var(--shadow-md);
  transform: translateY(-2px);
}

.recipe-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.5rem;
}

.recipe-card-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text);
  line-height: 1.35;
  flex: 1;
}

.cuisine-badge {
  font-size: 0.7rem;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 20px;
  background: var(--accent-glow);
  color: var(--accent);
  border: 1px solid rgba(99, 102, 241, 0.2);
  white-space: nowrap;
  flex-shrink: 0;
}

.recipe-card-meta {
  display: flex;
  gap: 1rem;
}

.recipe-meta-item {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.78rem;
  color: var(--text-muted);
}

.recipe-meta-item i {
  font-size: 0.7rem;
  color: var(--text-dim);
}

/* Match bar */
.match-bar-wrap {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.match-bar-track {
  flex: 1;
  height: 5px;
  background: var(--surface-3);
  border-radius: 99px;
  overflow: hidden;
}

.match-bar-fill {
  height: 100%;
  border-radius: 99px;
  transition: width 0.4s ease;
}

.match-bar-fill.high   { background: var(--success); }
.match-bar-fill.medium { background: var(--warning); }
.match-bar-fill.low    { background: var(--danger); }
.match-bar-fill.none   { background: var(--surface-3); width: 100% !important; }

.match-bar-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text-muted);
  min-width: 32px;
  text-align: right;
}

.recipe-card-actions {
  display: flex;
  gap: 0.4rem;
  padding-top: 0.5rem;
  border-top: 1px solid var(--border);
}

/* Empty state */
.empty-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: 4rem 2rem;
  color: var(--text-muted);
}

.empty-state i {
  font-size: 2.5rem;
  color: var(--text-dim);
  margin-bottom: 1rem;
}

.empty-state h5 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.empty-state p {
  font-size: 0.825rem;
  color: var(--text-dim);
}

/* --------------------------------------------------------------------------
   Browse Stats row (compact)
   -------------------------------------------------------------------------- */
.browse-stats-bar {
  display: flex;
  gap: 1.5rem;
  padding: 0.6rem 0;
  margin-bottom: 1.25rem;
  border-bottom: 1px solid var(--border);
}

.browse-stat {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
}

.browse-stat-value {
  font-size: 1rem;
  font-weight: 700;
  color: var(--accent);
}

.browse-stat-label {
  font-size: 0.75rem;
  color: var(--text-muted);
}

/* --------------------------------------------------------------------------
   Right-side Offcanvas Drawer (Recipe Detail)
   -------------------------------------------------------------------------- */
#recipe_detail_drawer {
  background: var(--surface) !important;
  border-left: 1px solid var(--border) !important;
  width: min(520px, 92vw) !important;
  color: var(--text);
}

#recipe_detail_drawer .offcanvas-header {
  background: var(--surface-2);
  border-bottom: 1px solid var(--border);
  padding: 1.25rem 1.5rem;
}

#recipe_detail_drawer .offcanvas-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
}

#recipe_detail_drawer .btn-close {
  filter: invert(1) brightness(0.7);
}

#recipe_detail_drawer .offcanvas-body {
  padding: 1.5rem;
  overflow-y: auto;
}

/* Recipe detail content inside drawer */
.drawer-meta-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.drawer-meta-item {
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0.85rem;
  text-align: center;
}

.drawer-meta-item .dm-label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-dim);
  margin-bottom: 0.35rem;
  font-weight: 600;
}

.drawer-meta-item .dm-value {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--accent);
}

.drawer-section {
  margin-bottom: 1.75rem;
}

.drawer-section-title {
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  font-weight: 700;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.drawer-section-title i {
  color: var(--accent);
  font-size: 0.75rem;
}

.ingredient-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.45rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.875rem;
}

.ingredient-row:last-child { border-bottom: none; }

.ingredient-row i {
  color: var(--success);
  font-size: 0.7rem;
  flex-shrink: 0;
}

.ingredient-row.missing i {
  color: var(--danger);
}

.step-row {
  display: flex;
  gap: 0.75rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.875rem;
}

.step-row:last-child { border-bottom: none; }

.step-num {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--accent-glow);
  color: var(--accent);
  font-size: 0.72rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}

/* Scale widget inside drawer */
.scale-widget {
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  margin-bottom: 1.75rem;
}

.scale-widget-title {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}

/* --------------------------------------------------------------------------
   Compare Modal
   -------------------------------------------------------------------------- */
.modal-content {
  background: var(--surface) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--radius) !important;
  color: var(--text) !important;
}

.modal-header {
  background: var(--surface-2) !important;
  border-bottom: 1px solid var(--border) !important;
  padding: 1.25rem 1.5rem !important;
}

.modal-header .modal-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text) !important;
}

.modal-header .btn-close {
  filter: invert(1) brightness(0.7) !important;
}

.modal-body {
  padding: 1.5rem !important;
}

.modal-footer {
  background: var(--surface-2) !important;
  border-top: 1px solid var(--border) !important;
}

/* --------------------------------------------------------------------------
   Forms & Inputs
   -------------------------------------------------------------------------- */
.form-control,
.form-select {
  background: var(--surface-2) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
  border-radius: var(--radius-sm) !important;
  font-size: 0.875rem !important;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.form-control:focus,
.form-select:focus {
  background: var(--surface-2) !important;
  border-color: var(--accent) !important;
  color: var(--text) !important;
  box-shadow: 0 0 0 3px var(--accent-glow) !important;
  outline: none;
}

.form-control::placeholder {
  color: var(--text-dim) !important;
}

.form-label,
label {
  color: var(--text-muted);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  margin-bottom: 0.4rem;
}

textarea.form-control {
  min-height: 140px;
  resize: vertical;
}

/* Shiny textInput/numericInput wrappers */
.form-group {
  margin-bottom: 1rem;
}

/* --------------------------------------------------------------------------
   Buttons
   -------------------------------------------------------------------------- */
.btn {
  border-radius: var(--radius-sm) !important;
  font-weight: 600 !important;
  font-size: 0.825rem !important;
  padding: 0.45rem 1rem !important;
  transition: all 0.15s ease !important;
  border: 1px solid transparent !important;
}

.btn:focus {
  box-shadow: 0 0 0 3px var(--accent-glow) !important;
}

.btn-primary {
  background: var(--accent) !important;
  border-color: var(--accent) !important;
  color: #fff !important;
}

.btn-primary:hover {
  background: var(--accent-dark) !important;
  border-color: var(--accent-dark) !important;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.35) !important;
}

.btn-secondary {
  background: var(--surface-3) !important;
  border-color: var(--border) !important;
  color: var(--text) !important;
}

.btn-secondary:hover {
  background: var(--border-light) !important;
  color: var(--text) !important;
}

.btn-success {
  background: var(--success) !important;
  border-color: var(--success) !important;
  color: #fff !important;
}

.btn-danger {
  background: var(--danger) !important;
  border-color: var(--danger) !important;
  color: #fff !important;
}

.btn-warning {
  background: var(--warning) !important;
  border-color: var(--warning) !important;
  color: #000 !important;
}

.btn-sm {
  padding: 0.3rem 0.7rem !important;
  font-size: 0.775rem !important;
}

.btn-lg {
  padding: 0.65rem 1.5rem !important;
  font-size: 0.9rem !important;
}

.btn-outline-primary {
  background: transparent !important;
  border-color: var(--accent) !important;
  color: var(--accent) !important;
}

.btn-outline-primary:hover {
  background: var(--accent-glow) !important;
}

.btn-outline-danger {
  background: transparent !important;
  border-color: var(--danger) !important;
  color: var(--danger) !important;
}

.btn-outline-danger:hover {
  background: rgba(239, 68, 68, 0.1) !important;
}

/* --------------------------------------------------------------------------
   DT DataTable Dark Theme
   -------------------------------------------------------------------------- */
.dataTables_wrapper {
  color: var(--text) !important;
}

.dataTables_wrapper .dataTable {
  color: var(--text) !important;
  border-collapse: separate !important;
  border-spacing: 0 !important;
}

.dataTables_wrapper .dataTable thead th {
  background: var(--surface-2) !important;
  color: var(--text-muted) !important;
  border-bottom: 1px solid var(--border) !important;
  font-size: 0.75rem !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.5px !important;
  padding: 0.75rem 1rem !important;
}

.dataTables_wrapper .dataTable tbody tr {
  background: var(--surface) !important;
  transition: background 0.15s;
}

.dataTables_wrapper .dataTable tbody tr:hover {
  background: var(--surface-2) !important;
}

.dataTables_wrapper .dataTable tbody td {
  border-bottom: 1px solid var(--border) !important;
  padding: 0.65rem 1rem !important;
  font-size: 0.85rem !important;
  color: var(--text) !important;
}

.dataTables_wrapper .dataTable tbody tr.selected td {
  background: var(--accent-glow) !important;
  color: var(--accent) !important;
}

.dataTables_length select,
.dataTables_filter input {
  background: var(--surface-2) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
  border-radius: var(--radius-sm) !important;
  padding: 0.2rem 0.5rem !important;
}

.dataTables_length label,
.dataTables_filter label,
.dataTables_info,
.dataTables_paginate .paginate_button {
  color: var(--text-muted) !important;
  font-size: 0.8rem !important;
}

.dataTables_paginate .paginate_button.current,
.dataTables_paginate .paginate_button.current:hover {
  background: var(--accent) !important;
  color: #fff !important;
  border: 1px solid var(--accent) !important;
  border-radius: var(--radius-sm) !important;
}

.dataTables_paginate .paginate_button:hover {
  background: var(--surface-2) !important;
  color: var(--text) !important;
  border: 1px solid var(--border) !important;
}

/* --------------------------------------------------------------------------
   Panel / Card (generic)
   -------------------------------------------------------------------------- */
.panel {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 1.5rem;
  overflow: hidden;
}

.panel-header {
  background: var(--surface-2);
  border-bottom: 1px solid var(--border);
  padding: 0.85rem 1.25rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel-header h5, .panel-header h6 {
  margin: 0;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text);
}

.panel-header i {
  color: var(--accent);
  margin-right: 0.5rem;
}

.panel-body {
  padding: 1.25rem;
}

/* --------------------------------------------------------------------------
   shinyWidgets PickerInput Dark
   -------------------------------------------------------------------------- */
.bootstrap-select .dropdown-toggle {
  background: var(--surface-2) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
  border-radius: var(--radius-sm) !important;
}

.bootstrap-select .dropdown-menu {
  background: var(--surface-2) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--radius-sm) !important;
}

.bootstrap-select .dropdown-item {
  color: var(--text) !important;
  font-size: 0.85rem !important;
}

.bootstrap-select .dropdown-item:hover,
.bootstrap-select .dropdown-item.active {
  background: var(--accent-glow) !important;
  color: var(--accent) !important;
}

/* --------------------------------------------------------------------------
   Radio buttons
   -------------------------------------------------------------------------- */
.radio label, .checkbox label {
  color: var(--text) !important;
  font-size: 0.875rem !important;
  font-weight: 400 !important;
  text-transform: none !important;
  letter-spacing: 0 !important;
}

/* --------------------------------------------------------------------------
   Alerts & Notifications
   -------------------------------------------------------------------------- */
.shiny-notification {
  background: var(--surface-2) !important;
  border: 1px solid var(--border) !important;
  border-left: 4px solid var(--accent) !important;
  color: var(--text) !important;
  border-radius: var(--radius) !important;
  box-shadow: var(--shadow-lg) !important;
  font-size: 0.875rem !important;
  font-weight: 500 !important;
  min-width: 280px !important;
}

.shiny-notification.shiny-notification-message { border-left-color: var(--success) !important; }
.shiny-notification.shiny-notification-error   { border-left-color: var(--danger) !important; }
.shiny-notification.shiny-notification-warning { border-left-color: var(--warning) !important; }

.shiny-notification-close {
  color: var(--text-dim) !important;
  filter: none !important;
}

/* --------------------------------------------------------------------------
   Shopping List
   -------------------------------------------------------------------------- */
.shop-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.875rem;
  color: var(--text);
}

.shop-item:last-child { border-bottom: none; }

/* --------------------------------------------------------------------------
   Scrollbar
   -------------------------------------------------------------------------- */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--surface-3); border-radius: 99px; }
::-webkit-scrollbar-thumb:hover { background: var(--border-light); }

/* --------------------------------------------------------------------------
   Focus ring (accessibility)
   -------------------------------------------------------------------------- */
:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
  box-shadow: 0 0 0 4px var(--accent-glow);
}

/* --------------------------------------------------------------------------
   Utility helpers
   -------------------------------------------------------------------------- */
.text-accent  { color: var(--accent) !important; }
.text-muted   { color: var(--text-muted) !important; }
.text-success { color: var(--success) !important; }
.text-danger  { color: var(--danger) !important; }
.text-warning { color: var(--warning) !important; }

.bg-surface   { background: var(--surface) !important; }
.bg-surface-2 { background: var(--surface-2) !important; }
.border-subtle { border-color: var(--border) !important; }

.divider {
  height: 1px;
  background: var(--border);
  margin: 1.25rem 0;
}

/* --------------------------------------------------------------------------
   Responsive — collapse sidebar on small screens
   -------------------------------------------------------------------------- */
@media (max-width: 768px) {
  #app-sidebar {
    transform: translateX(-100%);
  }

  #app-sidebar.sidebar-open {
    transform: translateX(0);
  }

  #main-content {
    margin-left: 0;
  }

  .content-pane {
    padding: 1.25rem 1rem;
  }

  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .recipe-cards-grid {
    grid-template-columns: 1fr;
  }

  .browse-stats-bar {
    flex-wrap: wrap;
    gap: 0.75rem;
  }
}
